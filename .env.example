# ═══════════════════════════════════════════════════════════════
#  MMA IQ — Modèle de variables d'environnement
#  Copie ce fichier en `.env` et remplis les valeurs.
#  `.env` est ignoré par git ; ce `.env.example` est versionné.
# ═══════════════════════════════════════════════════════════════

# ── Supabase (backend) ────────────────────────────────────────
VITE_SUPABASE_URL=https://tmmtabzxcgxlmsgfgxwx.supabase.co
VITE_SUPABASE_ANON_KEY=

# ── Admin ─────────────────────────────────────────────────────
# Email qui obtient le rôle super_admin dans l'app.
VITE_ADMIN_EMAIL=
# (Actuellement non lu par le code — le code d'accès du mode
#  édition CMS est géré côté client. Conservé pour référence.)
VITE_ADMIN_PASSWORD=

# ── Stripe (paiements) ────────────────────────────────────────
VITE_STRIPE_PUBLISHABLE_KEY=   # pk_test_... ou pk_live_... (navigateur)
STRIPE_SECRET_KEY=             # sk_test_... ou sk_live_... (serveur)

# ── Serveur ───────────────────────────────────────────────────
APP_URL=http://localhost:3000
